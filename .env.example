DATABASE_URL=postgres://postgres:root@localhost:5432/reading_ai?sslmode=disable
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
HTTP_ADDR=:8080
PAGE_CHUNK_SIZE=1000
APP_ENV=development

# Fase 3 — auth e freemium
JWT_SECRET=altere-em-producao
JWT_EXPIRY_HOURS=72
FREE_MAX_BOOKS=2
FREE_MAX_QUESTIONS_PER_DAY=10

# Fase 5 — storage S3 (MinIO local/AWS produção)
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
S3_BUCKET=leitura-inteligente
S3_ENDPOINT=http://localhost:9000
S3_USE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_UPLOAD_PART_SIZE_MB=8
S3_UPLOAD_CONCURRENCY=4

# Fase 6 — segurança (CORS, rate limit, métricas, upload)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://seu-frontend.com
AUTH_RATE_LIMIT_PER_MIN=30
UPLOAD_RATE_LIMIT_PER_MIN=20
MAX_UPLOAD_BYTES=52428800
METRICS_ENABLED=true
# METRICS_BASIC_USER=
# METRICS_BASIC_PASSWORD=
